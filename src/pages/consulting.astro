---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Consulting — Tim Raysby">
  <h1 class="text-4xl font-bold tracking-tight">Consulting</h1>
  <p class="mt-2 text-sm text-zinc-500">Local-AI architecture for teams that want sovereignty over their stack.</p>

  <div class="mt-10 p-6 border border-zinc-800 rounded-lg bg-zinc-900/50 max-w-xl">
    <p class="text-zinc-300">Currently fully booked.</p>
    <p class="mt-2 text-sm text-zinc-400">Engagement slots open quarterly. Get on the list and I'll reach out when a window opens.</p>

    <form class="mt-6 flex gap-2" action="#" method="post">
      <input type="email" placeholder="you@domain.com" required class="flex-1 bg-zinc-950 border border-zinc-700 rounded px-4 py-2 text-sm focus:outline-none focus:border-zinc-500" />
      <button type="submit" class="bg-zinc-100 text-zinc-950 px-4 py-2 rounded text-sm font-medium hover:bg-white">Notify me</button>
    </form>
  </div>

  <div class="mt-12 max-w-2xl text-sm text-zinc-400">
    <h2 class="text-zinc-100 font-medium text-base">What I work on</h2>
    <ul class="mt-3 space-y-2 list-disc list-inside">
      <li>Architecting on-premise AI stacks — Ollama, vLLM, custom routing</li>
      <li>Replacing cloud-AI subscriptions with sovereign equivalents</li>
      <li>Privacy-first internal tooling for content, research, and automation</li>
    </ul>
  </div>
</Layout>
