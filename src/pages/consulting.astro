---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Consulting — Tim Raysby">
  <p class="text-xs font-mono uppercase tracking-widest text-green mb-4 flex items-center gap-3">
    <span class="w-8 h-px bg-green"></span>
    Consulting
  </p>
  <h1 class="font-serif text-4xl md:text-5xl font-light tracking-tight">
    Local-AI architecture for teams that want <em>sovereignty</em>.
  </h1>

  <div class="mt-12 p-6 sm:p-8 border border-charcoal-lighter bg-charcoal-light max-w-xl relative">
    <div class="absolute -top-1 -left-1 w-3 h-3 border-l border-t border-green/60" aria-hidden="true"></div>
    <div class="absolute -top-1 -right-1 w-3 h-3 border-r border-t border-green/60" aria-hidden="true"></div>

    <p class="text-ink font-mono text-sm">Currently fully booked.</p>
    <p class="mt-2 text-xs text-ink-dim font-mono">Engagement slots open quarterly. Get on the list and I will reach out when a window opens.</p>

    <form
      id="consulting-waitlist-form"
      class="mt-6 flex flex-col sm:flex-row gap-2 sm:gap-0"
      action="/api/consulting-waitlist"
      method="post"
      novalidate
    >
      <input
        type="email"
        name="email"
        placeholder="you@domain.com"
        required
        autocomplete="email"
        class="flex-1 bg-charcoal border border-charcoal-lighter px-3 py-2 text-sm focus:outline-none focus:border-green text-ink font-mono min-w-0"
      />
      <button
        type="submit"
        id="consulting-waitlist-submit"
        class="bg-green text-charcoal px-4 py-2 text-xs font-mono font-medium uppercase tracking-widest hover:bg-green-deep transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
      >Notify Me</button>
    </form>
    <p id="consulting-waitlist-result" class="mt-3 text-xs font-mono" aria-live="polite"></p>
  </div>

  <script is:inline>
    (() => {
      const form = document.getElementById('consulting-waitlist-form');
      const submit = document.getElementById('consulting-waitlist-submit');
      const result = document.getElementById('consulting-waitlist-result');
      if (!form || !submit || !result) return;

      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const fd = new FormData(form);
        const email = String(fd.get('email') || '').trim();
        if (!email) {
          result.textContent = 'Please enter an email address.';
          result.className = 'mt-3 text-xs font-mono text-ink-dim';
          return;
        }
        submit.disabled = true;
        submit.textContent = 'Adding...';
        result.textContent = '';
        try {
          const resp = await fetch('/api/consulting-waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          let data = {};
          try { data = await resp.json(); } catch { /* ignore */ }
          if (resp.ok && data && data.ok) {
            result.textContent = "Got you. I'll reach out when a slot opens.";
            result.className = 'mt-3 text-xs font-mono text-green';
            form.reset();
          } else {
            const msg = (data && data.error) || 'Subscription failed. Please try again.';
            result.textContent = msg;
            result.className = 'mt-3 text-xs font-mono text-ink-dim';
          }
        } catch (e) {
          result.textContent = 'Could not reach the server. Please try again, or email contact@timraysby.com.';
          result.className = 'mt-3 text-xs font-mono text-ink-dim';
        } finally {
          submit.disabled = false;
          submit.textContent = 'Notify Me';
        }
      });
    })();
  </script>

  <div class="mt-16 max-w-2xl">
    <h2 class="text-xs font-mono uppercase tracking-widest text-green mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-green"></span>
      What I work on
    </h2>
    <ul class="space-y-3 text-sm text-ink-dim font-mono">
      <li class="flex gap-4"><span class="text-green-deep">[01]</span><span>Architecting on-premise AI stacks — Ollama, vLLM, custom routing</span></li>
      <li class="flex gap-4"><span class="text-green-deep">[02]</span><span>Replacing cloud-AI subscriptions with sovereign equivalents</span></li>
      <li class="flex gap-4"><span class="text-green-deep">[03]</span><span>Privacy-first internal tooling for content, research, and automation</span></li>
    </ul>
  </div>
</Layout>
