---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Shop — Tim Raysby">
  <h1 class="text-4xl font-bold tracking-tight">Shop</h1>
  <p class="mt-2 text-sm text-zinc-500">Merch, blueprints, digital products.</p>

  <div class="mt-12 grid md:grid-cols-2 gap-6">
    <div class="p-6 border border-zinc-800 rounded-lg bg-zinc-900/50">
      <div class="aspect-square bg-zinc-800 rounded mb-4 flex items-center justify-center text-center px-4">
        <span class="text-2xl font-bold tracking-tight text-zinc-100 leading-tight">MY TOKENS.<br/>MY BUSINESS.</span>
      </div>
      <h2 class="text-lg font-medium">Flagship Tee</h2>
      <p class="text-sm text-zinc-400 mt-1">The slogan, on cotton.</p>
      <p class="text-sm text-zinc-500 mt-3">Coming soon.</p>
    </div>

    <div class="p-6 border border-zinc-800 rounded-lg bg-zinc-900/50 opacity-60">
      <div class="aspect-square bg-zinc-800 rounded mb-4 flex items-center justify-center">
        <span class="text-zinc-500 text-sm">Future drop</span>
      </div>
      <h2 class="text-lg font-medium">Local-First AI Blueprint</h2>
      <p class="text-sm text-zinc-400 mt-1">PDF + repo template. Build your own NEXUS.</p>
      <p class="text-sm text-zinc-500 mt-3">Coming soon.</p>
    </div>
  </div>
</Layout>
