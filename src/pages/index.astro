---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="py-12">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-none">MY TOKENS.<br/>MY BUSINESS.</h1>
    <p class="mt-6 text-xl text-zinc-300 italic max-w-2xl">I build local-first AI systems that don't rent your data to anyone.</p>

    <form class="mt-10 flex gap-2 max-w-md" action="#" method="post">
      <input type="email" placeholder="you@domain.com" required class="flex-1 bg-zinc-900 border border-zinc-700 rounded px-4 py-3 text-sm focus:outline-none focus:border-zinc-500" />
      <button type="submit" class="bg-zinc-100 text-zinc-950 px-5 py-3 rounded text-sm font-medium hover:bg-white">Get the build log</button>
    </form>
    <p class="mt-3 text-xs text-zinc-500">Weekly. No spam. Unsubscribe anytime.</p>
  </section>

  <section class="py-12 border-t border-zinc-800 mt-12">
    <h2 class="text-sm uppercase tracking-wider text-zinc-500">What I'm doing</h2>
    <div class="mt-6 grid md:grid-cols-3 gap-6 text-sm">
      <a href="/writing" class="group">
        <h3 class="text-lg font-medium group-hover:text-white">Writing →</h3>
        <p class="text-zinc-400 mt-1">Essays, build logs, newsletter.</p>
      </a>
      <a href="/consulting" class="group">
        <h3 class="text-lg font-medium group-hover:text-white">Consulting →</h3>
        <p class="text-zinc-400 mt-1">Local-AI architecture for teams that want sovereignty.</p>
      </a>
      <a href="/shop" class="group">
        <h3 class="text-lg font-medium group-hover:text-white">Shop →</h3>
        <p class="text-zinc-400 mt-1">Merch, blueprints, digital products.</p>
      </a>
    </div>
  </section>
</Layout>
