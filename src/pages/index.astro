---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="py-12 relative">
    <div class="absolute -top-2 -left-2 w-3 h-3 border-l border-t border-green/60" aria-hidden="true"></div>
    <div class="absolute -top-2 -right-2 w-3 h-3 border-r border-t border-green/60" aria-hidden="true"></div>

    <p class="text-xs font-mono text-green mb-8 flex items-center">
      <span class="text-green">$</span>
      <span class="ml-2">whoami</span>
      <span class="ml-1 inline-block w-2 h-3 bg-green animate-pulse" aria-hidden="true"></span>
    </p>

    <h1 class="font-serif text-5xl md:text-7xl font-light tracking-tight leading-none">
      Tim Raysby
    </h1>

    <p class="mt-8 text-base md:text-lg text-ink-dim font-mono leading-relaxed max-w-prose">The AI economy rents your attention. I build the kind you keep.</p>
  </section>

  <section class="py-8">
    <p class="text-base md:text-lg text-ink leading-relaxed max-w-prose">
      I build AI systems that run on their own hardware &mdash; full stacks, no per-token bills, no vendor lock-in. By day I'm a senior engineer at a Fortune 100 insurer. Evenings I build <span class="text-green">NEXUS</span>, the personal AI infrastructure I'm building in public.
    </p>
  </section>

  <section class="py-12 border-t border-charcoal-lighter mt-6">
    <h2 class="text-xs font-mono uppercase tracking-widest text-green mb-8 flex items-center gap-3">
      <span class="w-8 h-px bg-green"></span>
      Where to start
    </h2>
    <div class="grid md:grid-cols-2 gap-8">
      <a href="/now" class="group block">
        <p class="font-mono text-xs text-green-deep">[01]</p>
        <h3 class="font-serif text-2xl mt-2 group-hover:text-green transition-colors">Building</h3>
        <p class="text-sm text-ink-dim mt-2 font-mono">What I'm building this week and the operators shaping how I think.</p>
      </a>
      <a href="/about" class="group block">
        <p class="font-mono text-xs text-green-deep">[02]</p>
        <h3 class="font-serif text-2xl mt-2 group-hover:text-green transition-colors">About</h3>
        <p class="text-sm text-ink-dim mt-2 font-mono">The longer version of who I am and why I build local-first.</p>
      </a>
    </div>
  </section>
</Layout>
