---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Writing — Tim Raysby">
  <p class="text-xs font-mono uppercase tracking-widest text-green mb-4 flex items-center gap-3">
    <span class="w-8 h-px bg-green"></span>
    Writing
  </p>
  <h1 class="font-serif text-4xl md:text-5xl font-light tracking-tight">
    Essays, build logs, <em>newsletter</em>.
  </h1>

  <div class="mt-12 max-w-prose space-y-3 text-sm text-ink-dim font-mono">
    <p>First post drops next weekend.</p>
    <p>Want it in your inbox? <a href="/" class="underline hover:text-green transition-colors">Sign up on the home page</a>.</p>
  </div>
</Layout>
