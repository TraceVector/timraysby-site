---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Writing — Tim Raysby">
  <p class="text-xs font-mono uppercase tracking-widest text-green mb-4 flex items-center gap-3">
    <span class="w-8 h-px bg-green"></span>
    Writing
  </p>
  <h1 class="font-serif text-4xl md:text-5xl font-light tracking-tight">
    Essays, build logs, <em class="italic text-green font-normal">newsletter.</em>
  </h1>

  <div class="mt-12 space-y-10 max-w-prose">
    <article>
      <p class="font-mono text-xs text-green-deep">[01]</p>
      <h2 class="font-serif text-xl sm:text-2xl mt-2">
        <a href="/writing/three-categories" class="hover:text-green transition-colors">Three Categories of AI Products in 2026</a>
      </h2>
      <p class="mt-2 text-xs font-mono text-ink-dimmer">Published 2026-05-14 · 5 min read</p>
      <p class="mt-3 text-sm text-ink-dim font-mono leading-relaxed">
        Most public AI businesses fall into one of three categories. Two are crowded. The third is where I work &mdash; local-first deterministic AI where the model proposes and code disposes.
      </p>
    </article>
  </div>

  <section class="mt-16 max-w-prose border-t border-charcoal-lighter pt-10">
    <p class="text-xs font-mono uppercase tracking-widest text-green mb-3 flex items-center gap-3">
      <span class="w-8 h-px bg-green"></span>
      Newsletter
    </p>
    <h2 class="font-serif text-2xl sm:text-3xl mt-2 font-light tracking-tight">
      One send. Sundays. <em class="italic text-green font-normal">Build logs and contrarian takes on the AI economy.</em>
    </h2>
    <p class="mt-4 text-sm text-ink-dim font-mono leading-relaxed">
      What I shipped that week, the thinking behind it, and the patterns I'm watching. No fluff, no roundups, no AI summaries of other people's tweets.
    </p>

    <form
      id="newsletter-form"
      class="mt-6 flex flex-col sm:flex-row gap-2 sm:gap-0"
      action="/api/newsletter-subscribe"
      method="post"
      novalidate
    >
      <input
        type="email"
        name="email"
        placeholder="you@domain.com"
        required
        autocomplete="email"
        class="flex-1 bg-charcoal border border-charcoal-lighter px-3 py-2 text-sm focus:outline-none focus:border-green text-ink font-mono min-w-0"
      />
      <button
        type="submit"
        id="newsletter-submit"
        class="bg-green text-charcoal px-4 py-2 text-xs font-mono font-medium uppercase tracking-widest hover:bg-green-deep transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
      >Subscribe</button>
    </form>
    <p id="newsletter-result" class="mt-2 text-xs font-mono" aria-live="polite"></p>
    <p class="mt-3 text-xs text-ink-dimmer font-mono">No spam. One-click unsubscribe. I read every reply.</p>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('newsletter-form');
      const submit = document.getElementById('newsletter-submit');
      const result = document.getElementById('newsletter-result');
      if (!form || !submit || !result) return;

      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const fd = new FormData(form);
        const email = String(fd.get('email') || '').trim();
        if (!email) {
          result.textContent = 'Please enter an email address.';
          result.className = 'mt-2 text-xs font-mono text-ink-dim';
          return;
        }
        const originalText = submit.textContent;
        submit.disabled = true;
        submit.textContent = 'Subscribing...';
        result.textContent = '';
        try {
          const resp = await fetch(form.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          let data = {};
          try { data = await resp.json(); } catch { /* ignore */ }
          if (resp.ok && data && data.ok) {
            result.textContent = "You're in. First Sunday send will land in your inbox.";
            result.className = 'mt-2 text-xs font-mono text-green';
            form.reset();
          } else {
            const msg = (data && data.error) || 'Subscription failed. Please try again.';
            result.textContent = msg;
            result.className = 'mt-2 text-xs font-mono text-ink-dim';
          }
        } catch (e) {
          result.textContent = 'Could not reach the server. Please try again, or email contact@timraysby.com.';
          result.className = 'mt-2 text-xs font-mono text-ink-dim';
        } finally {
          submit.disabled = false;
          submit.textContent = originalText;
        }
      });
    })();
  </script>
</Layout>
